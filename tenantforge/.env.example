# TenantForge — local env template. Copy to .env (git-ignored) and fill in. NO real secrets here.

# Control-plane registry Postgres (Neon). Holds tenant METADATA only — never tenant data.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Neon API — used to provision/delete an isolated project per tenant.
NEON_API_KEY=
# Neon organization id (this account is org-scoped; project operations require it).
NEON_ORG_ID=
# Override the Neon API base URL (optional; defaults to the public API).
# NEON_API_BASE_URL=https://console.neon.tech/api/v2

# Where per-tenant connection secrets live: `neon-pg` (default — AES-256-GCM-encrypted in the
# control-plane DB) or `vault` (HashiCorp Vault KV v2).
# TENANTFORGE_SECRET_BACKEND=neon-pg

# --- neon-pg backend (default) ---
# Encrypts per-tenant connection secrets at rest (AES-256-GCM). MUST be a long, high-entropy
# value and MUST be different from DATABASE_URL's password (separation of duties — a registry-DB
# compromise alone must not be able to decrypt connection secrets). Min 16 chars.
# Required only when TENANTFORGE_SECRET_BACKEND=neon-pg.
TENANTFORGE_SECRET_KEY=

# --- vault backend (set TENANTFORGE_SECRET_BACKEND=vault) ---
# VAULT_ADDR (https) and VAULT_TOKEN are required for the vault backend; the rest have defaults.
# VAULT_ADDR=https://vault.example.com:8200
# VAULT_TOKEN=
# VAULT_KV_MOUNT=secret
# VAULT_PATH_PREFIX=tenantforge
# VAULT_NAMESPACE=            # Vault Enterprise namespace, if any

# Retention window (days) an offboarded/archived tenant is kept before `purge-expired` deletes it.
# TENANTFORGE_RETENTION_DAYS=30

# Residency enforcement: comma-separated allow-list of regions tenants may be provisioned in.
# Empty/unset = all known regions allowed. e.g. EU-only: aws-eu-central-1,aws-eu-west-1,azure-gwc
# TENANTFORGE_ALLOWED_REGIONS=

# HTTP control-plane API.
TENANTFORGE_HTTP_TOKEN=
# TENANTFORGE_BASE_URL=http://localhost:3000
# TENANTFORGE_PORT=3000

# Async lifecycle worker: poll interval (ms) between drains of the Postgres-backed queue
# (tf_lifecycle_queue). Lower = lower latency, more idle queries. Default 5000.
# TENANTFORGE_QUEUE_POLL_MS=5000
