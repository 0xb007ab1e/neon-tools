# TenantForge — local env template. Copy to .env (git-ignored) and fill in. NO real secrets here.

# Control-plane registry Postgres (Neon). Holds tenant METADATA only — never tenant data.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Neon API — used to provision/delete an isolated project per tenant.
NEON_API_KEY=
# Neon organization id (this account is org-scoped; project operations require it).
NEON_ORG_ID=
# Override the Neon API base URL (optional; defaults to the public API).
# NEON_API_BASE_URL=https://console.neon.tech/api/v2

# Deployment context. `production` is fail-fast/secure-by-default and REQUIRES a real erasure
# signing key below (no ephemeral fallback). Anything else (default `development`) is non-prod:
# if the signing key is unset, an EPHEMERAL Ed25519 key is generated at startup (with a warning;
# not verifiable across restarts). One of: development | test | staging | production.
# TENANTFORGE_ENV=development

# --- Erasure certificate signing (always-signed; GDPR Art.17 evidence) ---
# Ed25519 PRIVATE signing key for erasure certificates (EdDSA compact JWS). A SECRET — from the
# secret manager / env, never committed or logged. Accepts a PKCS#8 PEM (-----BEGIN PRIVATE KEY-----)
# or a private JWK as JSON ({"kty":"OKP","crv":"Ed25519","d":"...","x":"..."}).
# REQUIRED in production; in non-prod an ephemeral key is generated when unset.
# Generate one (PKCS#8 PEM): openssl genpkey -algorithm ED25519
# Verify a certificate with the published public key:
#   tenantforge erasure-cert-pubkey > pub.jwk
#   tenantforge erasure-cert-verify --jws cert.jws --pubkey pub.jwk
# TENANTFORGE_ERASURE_SIGNING_KEY=

# Ed25519 private signing key for SIGNED COMPLIANCE REPORTS (EdDSA JWS; ADR-0011). Same format as the
# erasure key (PKCS#8 PEM or private JWK) but a DISTINCT purpose/kid so the two artifact classes can't
# be confused. REQUIRED in production for `signedComplianceReport()`; in non-prod an ephemeral key is
# generated when unset. The unsigned `complianceReport()` (digest-only) needs no key.
# Generate one (PKCS#8 PEM): openssl genpkey -algorithm ED25519
# TENANTFORGE_COMPLIANCE_SIGNING_KEY=

# Where per-tenant connection secrets live: `neon-pg` (default — AES-256-GCM-encrypted in the
# control-plane DB) or `vault` (HashiCorp Vault KV v2).
# TENANTFORGE_SECRET_BACKEND=neon-pg

# --- neon-pg backend (default) ---
# Encrypts per-tenant connection secrets at rest (AES-256-GCM). MUST be a long, high-entropy
# value and MUST be different from DATABASE_URL's password (separation of duties — a registry-DB
# compromise alone must not be able to decrypt connection secrets). Min 16 chars.
# Required only when TENANTFORGE_SECRET_BACKEND=neon-pg.
TENANTFORGE_SECRET_KEY=

# --- vault backend (set TENANTFORGE_SECRET_BACKEND=vault) ---
# VAULT_ADDR (https) and VAULT_TOKEN are required for the vault backend; the rest have defaults.
# VAULT_ADDR=https://vault.example.com:8200
# VAULT_TOKEN=
# VAULT_KV_MOUNT=secret
# VAULT_PATH_PREFIX=tenantforge
# VAULT_NAMESPACE=            # Vault Enterprise namespace, if any

# Offboard export strategy: `neon-archive` (default — retain the Neon project, scale-to-zero) or
# `pg-dump` (dump the tenant DB to an object store). pg-dump needs an absolute artifact directory
# (a mounted/durable volume) until S3/GCS object-store backends land.
# TENANTFORGE_EXPORTER=neon-archive
# EXPORT_DIR also enables the scheduled off-Neon ARCHIVE tier (tf archive / archive-fleet → the
# `archives/` prefix); without it, archive() fails closed. Archive retention = object-store lifecycle.
# TENANTFORGE_EXPORT_DIR=/var/lib/tenantforge/exports

# Retention window (days) an offboarded/archived tenant is kept before `purge-expired` deletes it.
# TENANTFORGE_RETENTION_DAYS=30

# Residency enforcement: comma-separated allow-list of regions tenants may be provisioned in.
# Empty/unset = all known regions allowed. e.g. EU-only: aws-eu-central-1,aws-eu-west-1,azure-gwc
# TENANTFORGE_ALLOWED_REGIONS=

# HTTP control-plane API auth mode: `token` (default — static credentials below) or `oidc`
# (verify a Bearer JWT against an external issuer's JWKS — phishing-resistant, no shared secrets).
# TENANTFORGE_AUTH_MODE=token
#
# --- token mode --- TENANTFORGE_HTTP_TOKEN is the single-admin shorthand.
TENANTFORGE_HTTP_TOKEN=
# For per-operator identity + RBAC, set comma-separated `id:role:token` entries instead
# (role = admin | operator | readonly — admin: all; operator: lifecycle but NOT purge; readonly:
# read. The token may contain colons — only the first two split). e.g.:
# TENANTFORGE_HTTP_CREDENTIALS=alice:admin:s3cret-a,bob:readonly:s3cret-b,carol:operator:s3cret-c
#
# --- oidc mode --- (required when TENANTFORGE_AUTH_MODE=oidc). The role comes from a token claim
# (default `role`) and must be `admin` | `operator` | `readonly`; the principal id from `sub`.
# TENANTFORGE_OIDC_ISSUER=https://your-idp.example.com/
# TENANTFORGE_OIDC_AUDIENCE=tenantforge
# TENANTFORGE_OIDC_JWKS_URI=https://your-idp.example.com/.well-known/jwks.json
# TENANTFORGE_OIDC_SUBJECT_CLAIM=sub
# TENANTFORGE_OIDC_ROLE_CLAIM=role
# Optional: a claim carrying an explicit permission array (e.g. ["tenant:read","tenant:provision"])
# that overrides the role's defaults — lets the IdP scope a token down per operation.
# TENANTFORGE_OIDC_PERMISSIONS_CLAIM=permissions
# Per-principal HTTP rate limit (fixed window). Defaults: 120 requests / 60000 ms.
# TENANTFORGE_RATE_LIMIT=120
# TENANTFORGE_RATE_WINDOW_MS=60000
# Rate-limit counter store: `memory` (default, per-instance) or `pg` (shared across instances via
# the control-plane DB — use for multi-instance deployments). In MULTI-REPLICA production `memory`
# can't enforce a global limit (each replica counts independently) — startup logs a non-fatal
# warning when ENV=production + memory (single-replica is fine; set `pg` for multi-replica).
# TENANTFORGE_RATE_LIMIT_STORE=memory
# Idempotency-key store: `memory` (default, per-instance) or `pg` (shared across instances so a POST
# retry that lands on another replica still replays the original response). In MULTI-REPLICA
# production `memory` replay-protection is per-instance (a retry on another replica re-executes) —
# startup logs a non-fatal warning when ENV=production + memory; set `pg` for multi-replica.
# TENANTFORGE_IDEMPOTENCY_STORE=memory
# Pending-erasure (undo-window) store: `memory` (default, per-instance) or `pg` (durable +
# cross-replica — `tf_pending_erasures`, migration 0012). `pg` makes the cancel/claim flips atomic
# across replicas and survive restarts — the prerequisite for enabling
# TENANTFORGE_PORTAL_SELFSERVE_DESTRUCTIVE in a multi-replica / restart-sensitive deployment
# (threat-model B8w / red-team F2, ADR-0010). REQUIRED to be `pg` (fail-closed at startup) whenever
# TENANTFORGE_PORTAL_SELFSERVE_DESTRUCTIVE=true — `memory` reopens the cancel-vs-execute race.
# TENANTFORGE_PENDING_ERASURE_STORE=memory
# Evidence-at-rest store for signed compliance bundles (ADR-0011 Phase 3a/3b): `memory` (default,
# per-instance dev/test); `object-store` (signed body durable in the export object store — requires
# TENANTFORGE_EXPORT_DIR; encrypt-at-rest is the object store's concern — but the manifest index is
# in-process, so get/list do NOT survive restart, the 3a limitation); or `pg` (the **durable** index:
# manifest + no-secret signed body in Postgres `tf_evidence_bundles`, migration 0013 — get/list/prune
# survive restart and hold across replicas; the production backend for the Phase 3b retrieval surface,
# uses DATABASE_URL). Non-guessable, tenant-scoped keys. Mirrors TENANTFORGE_PENDING_ERASURE_STORE.
# REQUIRED to be `pg` (fail-closed at startup) when TENANTFORGE_ENV=production: `memory` loses
# evidence on restart and `object-store`'s manifest index is in-process (get/list break after
# restart) — neither is durable for auditable retrieval.
# TENANTFORGE_EVIDENCE_STORE=memory
# Default retention window (days) recorded on a persisted evidence bundle; `0` (default) = indefinite
# retention (auditors keep evidence durably). Drives `retentionUntil` + the `evidence-prune` sweep.
# TENANTFORGE_EVIDENCE_RETENTION_DAYS=0
# Persisted audit trail: `none` (default — stdout JSON event stream only) or `pg` (durable,
# queryable `tf_audit_log`). `pg` enables erasure-history + recent-excerpt in the compliance report
# and survives restarts/multi-instance. Requires migration 0006. Retention is governed by your
# data-lifecycle policy (periodically prune old rows).
# TENANTFORGE_AUDIT_LOG=none
# Credit ledger (downgrade credits + applying credit to charges): `none` (off — downgrades fall back
# to a capped refund), `memory` (process-local; dev/single-instance), or `pg` (durable + authoritative
# — tf_credits, migration 0007; recommended in production). A charge draws down credit before billing.
# TENANTFORGE_CREDIT_LEDGER=none
# Signup/invite token store (self-serve onboarding): `none` (off), `memory` (process-local;
# dev/single-instance), or `pg` (durable — tf_signup_tokens, migration 0008). Enables issuing a
# one-time token that provisions a tenant on redemption. Only the token HASH is stored. Issue/redeem
# are CLI/library only (they provision resources); listing is read-only on HTTP/dashboard.
# TENANTFORGE_SIGNUP_TOKEN_STORE=none
# Cache getConnection resolutions for this many ms (0 = disabled). Process-local, tenant-keyed,
# invalidated on lifecycle changes. Reduces registry+secret lookups for hot tenants at fleet scale.
# TENANTFORGE_CONNECTION_CACHE_TTL_MS=0
# --- transport security (TLS) ---
# Every outbound connection enforces TLS by default and fails closed otherwise (master §5). These
# two flags are LOCAL-DEV-ONLY escape hatches for a loopback service with no certificate — the
# documented "leaky endpoints" (README §Security: TLS). NEVER set either in production.
# TENANTFORGE_ALLOW_INSECURE_DB=false   # permit a non-TLS Postgres connection (no sslmode=require)
# TENANTFORGE_ALLOW_INSECURE_URLS=false # permit a non-https outbound URL (Neon/Vault/KV/OIDC/Stripe)

# Web dashboard (optional): set an HMAC key to mount the cookie-session dashboard backend at
# /dashboard (the browser UI logs in with an operator token → HttpOnly session cookie). Unset =
# dashboard disabled. MUST be >= 32 chars — it signs the session + CSRF cookies/tokens, so a short
# key is forgeable (gap #8). Use a long random value; rotate like any secret.
# TENANTFORGE_DASHBOARD_SECRET=
# Path to the built SPA (`dashboard/dist`, from `pnpm dashboard:build`); set it and the control-plane
# server also serves the dashboard front-end under /dashboard (no separate web server needed). Unset
# = JSON API only (the SPA is served by Vite in dev). Requires TENANTFORGE_DASHBOARD_SECRET too.
# TENANTFORGE_DASHBOARD_DIST=./dashboard/dist
# Directory of ordered migration .sql files (the catalog). Set it and the dashboard can EXECUTE a
# fleet reconcile (tenant:provision-gated) — the server loads the SQL from here. Unset = reconcile is
# preview-only in the browser (execution stays the `reconcile-fleet` CLI op).
# TENANTFORGE_MIGRATIONS_DIR=./migrations/tenant
# Tenant self-serve portal (optional): set an HMAC key (signs portal session cookies) AND the
# per-tenant credentials to mount the customer-facing portal at /portal. Each tenant signs in with
# its token and sees ONLY its own account/charges/refunds (tenant id is derived server-side from the
# session, never from request input). Tokens are secrets — long + random; rotate like any secret. The
# PORTAL_SECRET MUST be >= 32 chars — it signs the session + CSRF cookies/tokens (gap #8).
# TENANTFORGE_PORTAL_SECRET=
# Portal auth mode: `token` (default — the static credentials below) or `oidc` (verify a customer
# IdP's JWT and read the tenant id from a claim — the production option). For `oidc`, set the
# PORTAL_OIDC_* below instead of CREDENTIALS.
# TENANTFORGE_PORTAL_AUTH_MODE=token
# Comma-separated tenantId:token pairs (the token authenticates as exactly that tenant) — token mode.
# TENANTFORGE_PORTAL_CREDENTIALS=11111111-1111-1111-1111-111111111111:REPLACE_WITH_RANDOM_TOKEN
# Portal OIDC (when TENANTFORGE_PORTAL_AUTH_MODE=oidc): the customer IdP's issuer / audience / JWKS,
# and the JWT claim carrying the tenant id (default `tenant`). The JWKS must be https.
# TENANTFORGE_PORTAL_OIDC_ISSUER=https://idp.example.com
# TENANTFORGE_PORTAL_OIDC_AUDIENCE=tenantforge-portal
# TENANTFORGE_PORTAL_OIDC_JWKS_URI=https://idp.example.com/.well-known/jwks.json
# TENANTFORGE_PORTAL_OIDC_TENANT_CLAIM=tenant
# Server-side Authorization Code + PKCE for the portal SPA login (H1/H2). The server generates +
# pins state/nonce/code_verifier; the SPA only redirects to the authorize URL and posts back the
# code+state — it never handles a raw token. All required when PORTAL_AUTH_MODE=oidc.
# TENANTFORGE_PORTAL_OIDC_AUTHORIZE_URL=https://idp.example.com/authorize
# TENANTFORGE_PORTAL_OIDC_TOKEN_URL=https://idp.example.com/token
# TENANTFORGE_PORTAL_OIDC_REDIRECT_URI=https://portal.example.com/portal/
# OAuth client id (defaults to the audience) and scope (defaults to `openid`).
# TENANTFORGE_PORTAL_OIDC_CLIENT_ID=tenantforge-portal
# TENANTFORGE_PORTAL_OIDC_SCOPE=openid
# Optional OAuth client secret (confidential client) — a secret; from the secret manager / env, never
# committed. Omit for a public client (PKCE alone authenticates the code exchange).
# TENANTFORGE_PORTAL_OIDC_CLIENT_SECRET=
# Self-serve portal write surface (ADR-0010 / threat-model B8w). The destructive actions (cancel +
# erasure) ship OFF until security-reviewed (red-team F6); set to `true` only when ready. The
# payment/plan/invoice reads + writes are always available when the portal is mounted.
# TENANTFORGE_PORTAL_SELFSERVE_DESTRUCTIVE=false
# Self-serve compliance-evidence surface (ADR-0011 Phase 3d / threat-model B8e): when `true`, a tenant
# can list/download its OWN signed evidence bundles + the public key and self-generate its own current
# bundle from the portal. A benign, default-OFF rollout flag for staged rollout of a new customer-facing
# surface — NON-DESTRUCTIVE, so it is INDEPENDENT of TENANTFORGE_PORTAL_SELFSERVE_DESTRUCTIVE (do not
# entangle the two). Requires an evidence signer/store wired for content (see EVIDENCE settings above).
# TENANTFORGE_PORTAL_SELFSERVE_EVIDENCE=false
# Path to the built portal SPA (`portal/dist`, from `pnpm portal:build`); set it (with the portal
# mounted) and the control-plane server also serves the customer-facing front-end under /portal
# (scoped CSP allows Stripe.js). Unset = JSON API + the server-rendered no-JS page (Vite serves the
# SPA in dev). The portal SPA's Stripe Elements use the public STRIPE_PUBLISHABLE_KEY (above).
# TENANTFORGE_PORTAL_DIST=./portal/dist
# TTL (ms) for a portal step-up second-factor code (cancel/erasure). Default 10 minutes.
# TENANTFORGE_PORTAL_STEPUP_TTL_MS=600000
# Mandatory erasure undo window (ms) — how long a tenant may cancel a scheduled erasure before it
# executes. Default 48h; keep window + execution within the statutory erasure SLA.
# TENANTFORGE_PORTAL_ERASURE_UNDO_WINDOW_MS=172800000
# Unit cost rates for the cost/margin report, as a JSON object of USD-per-unit numbers (Neon's
# prices for your plan). Unset = zero cost (margin = price). Per-tenant price lives in tenant
# metadata.priceUsd. e.g. {"computeSecondUsd":0.00016,"storageByteUsd":1.5e-10}
# TENANTFORGE_COST_RATES=
# Per-unit BILLING (sell) rates for invoice generation — same JSON shape as the cost rates, but the
# prices you CHARGE tenants (distinct from your Neon cost). Unset = usage not billed (invoice = the
# plan fee from metadata.priceUsd only). Generates invoice documents; it does NOT charge a card.
# TENANTFORGE_BILLING_RATES={"computeSecondUsd":0.0005,"storageByteUsd":5e-10}
# Usage-alert thresholds: comma-separated fractions of a tenant's included allowance to alert at
# (e.g. 0.8,1.0 = warn at 80% and at 100%). Empty/unset = usage alerts off. Applies YOUR per-tenant
# plan-allowance policy on top of Neon's metering (Neon has no notion of your plan tiers) — run the
# sweep via the CLI (`usage-alerts [--notify]`); HTTP/dashboard show alert history read-only.
# TENANTFORGE_USAGE_ALERT_THRESHOLDS=0.8,1.0
# The operator plan catalog as a JSON array of named tiers. Assigning a plan (CLI `assign-plan`)
# sets a tenant's price + included allowances at once. Empty/unset = no catalog. YOUR product tiers —
# Neon has no concept of them. Validated at load (fail loud on bad ids/numbers).
# TENANTFORGE_PLANS=[{"id":"starter","name":"Starter","priceUsd":0,"includedUsage":{"computeTimeSeconds":3600}},{"id":"pro","name":"Pro","priceUsd":49,"includedUsage":{"computeTimeSeconds":360000}}]
# Payment gateway for CHARGING invoices: `none` (default — charging disabled) or `stripe`. Charging
# moves money — opt-in only, CLI-gated (`charge` / `charge-fleet --yes`), never HTTP/MCP. The tenant's
# PSP customer id lives in metadata.billingCustomerRef. Swap providers behind the PaymentGateway port.
# `stripe` requires STRIPE_SECRET_KEY (a secret; never committed/logged).
# TENANTFORGE_PAYMENT_GATEWAY=none
# STRIPE_SECRET_KEY=sk_live_or_test_...
# STRIPE_API_BASE_URL=https://api.stripe.com   # override for a mock/proxy (optional)
# Stripe WEBHOOK signing secret (whsec_…) — distinct from the API key. When set (with
# paymentGateway=stripe), the inbound webhook endpoint POST /webhooks/payment is mounted and verifies
# event signatures with it (signature-authed, not bearer). A secret; never committed/logged.
# TENANTFORGE_PAYMENT_WEBHOOK_SECRET=whsec_...

# Outbound lifecycle webhook (optional): HMAC-signed POST of each control-plane event to an external
# endpoint (billing/CRM/alerting). URL must be https; set URL + SECRET together. Optional comma-
# separated event-name allow-list (empty = all events).
# TENANTFORGE_WEBHOOK_URL=https://hooks.example.com/tenantforge
# TENANTFORGE_WEBHOOK_SECRET=
# TENANTFORGE_WEBHOOK_EVENTS=tenant.provisioned,tenant.erased
# Billing receipts (optional): `none` (default), `log` (auditable receipt trail, no external send),
# or `http` (POST each receipt to a relay — requires NOTIFIER_URL, must be https; optional HMAC
# secret). A successful charge/refund best-effort emails the tenant's metadata.billingEmail.
# TENANTFORGE_NOTIFIER=none
# TENANTFORGE_NOTIFIER_URL=https://mail-relay.example.com/send
# TENANTFORGE_NOTIFIER_SECRET=
# TENANTFORGE_BASE_URL=http://localhost:3000
# TENANTFORGE_PORT=3000

# Async lifecycle worker: poll interval (ms) between drains of the Postgres-backed queue
# (tf_lifecycle_queue). Lower = lower latency, more idle queries. Default 5000.
# TENANTFORGE_QUEUE_POLL_MS=5000

# Public self-serve signup (optional): set an HMAC key (signs the short-lived signup-session cookie)
# to enable the payment-gated /signup sub-app. Requires Stripe + a captcha + a notifier (enforced at
# config load). MUST be >= 32 chars — it signs the signup-session cookie, so a short key is forgeable
# (gap #8). A secret; never committed/logged.
# TENANTFORGE_SIGNUP_SECRET=

# /metrics access token (optional, defense-in-depth — gap #17). When SET, GET /metrics requires
# `Authorization: Bearer <token>` (constant-time compare) or returns 401; UNSET keeps /metrics
# unauthenticated so default Prometheus scraping is unbroken. NOTE: /metrics, /health, and /ready MUST
# NOT be publicly routable — scope them to the metrics/admin network. The primary control is network
# isolation; this token is defense-in-depth, NOT a substitute. A secret; never committed/logged.
# TENANTFORGE_METRICS_TOKEN=
