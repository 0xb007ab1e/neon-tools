# Build output
dist
*.tsbuildinfo

# Test / coverage artifacts
coverage

# Mutation testing (Stryker) — generated HTML report + scratch dir
reports
.stryker-tmp

# Generated API docs (built in CI / on release — master §1: committing generated HTML is optional)
docs/api

# Local env — never commit real secrets (workflow-secrets); .env.example is committed
.env
.env.*
!.env.example

# Editor swap/backup files (can mirror an open .env — keep them out of VCS)
*.swp
*.swo
*~
.*.kate-swp
.*.kate-swp.*

# Node
node_modules
