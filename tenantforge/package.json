{
  "name": "@neon-tools/tenantforge",
  "version": "0.7.0",
  "type": "module",
  "description": "Control plane for database-per-tenant SaaS on Neon: provision an isolated project per customer, route connections, orchestrate fleet migrations, and manage tenant lifecycle.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "tenantforge": "./dist/app/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/app/lib.d.ts",
      "import": "./dist/app/lib.js"
    }
  },
  "files": [
    "dist",
    "dashboard/dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && pnpm dashboard:build",
    "version:check": "node scripts/check-version.mjs",
    "cli": "node --env-file-if-exists=.env --import tsx src/app/cli.ts",
    "http": "node --env-file-if-exists=.env --import tsx src/app/http.ts",
    "mcp": "node --env-file-if-exists=.env --import tsx src/app/mcp.ts",
    "worker": "node --env-file-if-exists=.env --import tsx src/app/worker.ts",
    "load": "node --import tsx src/app/load.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p dashboard/tsconfig.json --noEmit",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "docs": "typedoc",
    "test": "vitest run --coverage && pnpm test:dashboard",
    "test:watch": "vitest",
    "test:int": "vitest run --config vitest.integration.config.ts",
    "test:dashboard": "vitest run --config dashboard/vitest.config.ts",
    "dashboard:dev": "vite --config dashboard/vite.config.ts",
    "dashboard:build": "vite build --config dashboard/vite.config.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "citty": "^0.1.6",
    "hono": "^4.12.25",
    "jose": "^6.2.3",
    "pg": "^8.13.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsdoc": "^50.6.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typedoc": "^0.28.19",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^8.0.16",
    "vitest": "^3.2.6",
    "vitest-axe": "^0.1.0",
    "yaml": "^2.9.0"
  }
}
