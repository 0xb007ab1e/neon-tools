# VectorNest — local env template. Copy to .env (git-ignored) and fill in. NO real secrets here.

# Neon Postgres connection string (use a least-privilege role, not the owner/superuser).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# OpenAI-compatible embeddings endpoint (base URL including the /v1 segment).
#   Cloudflare Workers AI: https://api.cloudflare.com/client/v4/accounts/<ACCOUNT_ID>/ai/v1
#   Ollama (local, keyless): http://localhost:11434/v1
EMBEDDINGS_BASE_URL=

# Bearer token for the endpoint. Required for hosted providers (e.g. a Cloudflare API token
# with Workers AI access); leave empty for keyless local servers like Ollama.
EMBEDDINGS_API_KEY=

# Embedding model (optional; default @cf/baai/bge-base-en-v1.5, 768-dim).
VECTORNEST_MODEL=@cf/baai/bge-base-en-v1.5
# Embedding dimension — only required if the model is not in the known-dimensions table.
# VECTORNEST_EMBED_DIM=768
# Max texts per embedding request (optional; default 64).
# VECTORNEST_EMBED_BATCH_SIZE=64

# Neon API — only needed for branch-based re-embed (Month-1; creating/deleting branches).
NEON_API_KEY=
NEON_PROJECT_ID=
