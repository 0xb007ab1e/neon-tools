# VectorNest — local env template. Copy to .env (git-ignored) and fill in. NO real secrets here.

# Neon Postgres connection string (use a least-privilege role, not the owner/superuser).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Vercel AI Gateway key for embedding models (provider/model strings, e.g. openai/text-embedding-3-small).
AI_GATEWAY_API_KEY=

# Neon API — only needed for branch-based re-embed (creating/deleting branches).
NEON_API_KEY=
NEON_PROJECT_ID=

# Base URL when running the (v2) HTTP entrypoint.
VECTORNEST_BASE_URL=http://localhost:3000
